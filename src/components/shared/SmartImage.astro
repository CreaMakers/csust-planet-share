---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  width?: number;
  height?: number;
  widths?: number[];
  sizes?: string;
  format?: "avif" | "png" | "webp" | "jpeg" | "jpg";
  densities?: number[];
  priority?: boolean;
  wrapperClass?: string;
  imageClass?: string;
  radiusClass?: string;
  skeletonClass?: string;
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  widths,
  sizes,
  format,
  densities,
  priority = false,
  wrapperClass = "",
  imageClass = "",
  radiusClass = "rounded-[1.75rem]",
  skeletonClass = "",
  class: legacyImageClass = "",
} = Astro.props as Props;

const resolvedWidth = width ?? src.width;
const resolvedHeight = height ?? src.height;
const aspectRatio = resolvedWidth > 0 && resolvedHeight > 0 ? `${resolvedWidth} / ${resolvedHeight}` : undefined;
const rootStyle = aspectRatio ? `aspect-ratio: ${aspectRatio};` : undefined;
const mergedImageClass = ["smart-image__asset", legacyImageClass, imageClass].filter(Boolean).join(" ");
const mergedWrapperClass = ["smart-image", radiusClass, wrapperClass].filter(Boolean).join(" ");
const mergedSkeletonClass = ["smart-image__skeleton", skeletonClass].filter(Boolean).join(" ");
---

<div data-smart-image-root data-loaded="false" class={mergedWrapperClass} style={rootStyle}>
  <div aria-hidden="true" class={mergedSkeletonClass}></div>
  <Image
    src={src}
    alt={alt}
    width={width}
    height={height}
    widths={widths}
    sizes={sizes}
    format={format}
    densities={densities}
    priority={priority}
    class={mergedImageClass}
  />
</div>

<script is:inline>
  (() => {
    const roots = Array.from(document.querySelectorAll("[data-smart-image-root]"));

    const markLoaded = (root) => {
      if (!(root instanceof HTMLElement)) {
        return;
      }
      root.dataset.loaded = "true";
    };

    roots.forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.smartImageReady === "true") {
        return;
      }

      root.dataset.smartImageReady = "true";

      const image = root.querySelector("img");
      if (!(image instanceof HTMLImageElement)) {
        return;
      }

      if (image.complete) {
        markLoaded(root);
        return;
      }

      image.addEventListener("load", () => markLoaded(root), { once: true });
      image.addEventListener("error", () => markLoaded(root), { once: true });
    });
  })();
</script>
