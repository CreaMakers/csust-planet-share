---
import type { PageSection } from "../../data/shared";

interface Props {
  sections: readonly PageSection[];
}

const { sections } = Astro.props as Props;
---

<nav aria-label="页面导航" class="hidden items-center gap-0.5 md:flex">
  {
    sections.map((section) => (
      <a href={`#${section.id}`} data-section-link data-smooth-scroll class="apple-nav-link rounded-full px-2 py-1 text-sm font-medium">
        {section.label}
      </a>
    ))
  }
</nav>

<nav aria-label="移动端页面导航" class="flex flex-col gap-1 border-t border-[var(--nav-border)] pt-3 md:hidden">
  {
    sections.map((section) => (
      <a href={`#${section.id}`} data-section-link data-topbar-menu-link data-mobile-section-link data-smooth-scroll class="apple-nav-link rounded-2xl px-4 py-3 text-sm font-medium hover:bg-[var(--control-bg)]">
        {section.label}
      </a>
    ))
  }
</nav>
