---
import { ExternalLink, FlaskConical } from "@lucide/astro";
import { siAndroid, siAppstore } from "simple-icons";
import type { InstallOption } from "../../data/shared";

interface Props {
  sectionId: string;
  options: readonly InstallOption[];
  title?: string;
  description?: string;
  singleColumn?: boolean;
}

const props = Astro.props as Props;
const { sectionId, options, title = "安装方式", description = "选择最适合你的方式，快速安装长理星球。" } = props;
const singleColumn = props.singleColumn ?? options.length === 1;
---

<section id={sectionId} class="apple-section apple-section--light w-full scroll-mt-28 py-24 md:py-32 sm:scroll-mt-32">
  <div class="apple-section__inner">
    <div class="mb-14 text-center md:mb-16">
      <h2 class="apple-section-title">{title}</h2>
      <p class="apple-body apple-body--muted mx-auto mt-5 max-w-3xl text-xl md:text-2xl">{description}</p>
    </div>

    <div class:list={["apple-card-grid gap-7", singleColumn ? "mx-auto max-w-3xl" : "apple-card-grid--two"]}>
      {
        options.map((option) => (
          <a href={option.href} target="_blank" rel="noopener noreferrer" class="apple-card group flex h-full flex-col p-8">
            <div class="mb-5 flex items-center gap-4">
              {option.icon === "appstore" ? (
                <div class="inline-flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[var(--page-text)] text-[var(--page-bg)]">
                  <svg viewBox="0 0 24 24" class="h-7 w-7" fill="currentColor" aria-hidden="true">
                    <path d={siAppstore.path} />
                  </svg>
                </div>
              ) : option.icon === "testflight" ? (
                <div class="inline-flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[var(--control-bg)]">
                  <FlaskConical class="h-7 w-7 text-[var(--color-blue)]" aria-hidden="true" />
                </div>
              ) : (
                <div class="inline-flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[var(--control-bg)]">
                  <svg viewBox="0 0 24 24" class="h-7 w-7 text-[var(--color-blue)]" fill="currentColor" aria-hidden="true">
                    <path d={siAndroid.path} />
                  </svg>
                </div>
              )}
              <h3 class="apple-title-3">{option.title}</h3>
            </div>
            <p class="apple-body apple-body--muted text-lg">{option.description}</p>
            <span class="apple-link mt-7 inline-flex items-center gap-1 text-base font-medium">
              {option.ctaLabel}
              <ExternalLink class="h-4 w-4" aria-hidden="true" />
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
