---
import { Menu, X } from "@lucide/astro";

interface Props {
  installSectionId: string;
  label?: string;
}

const { installSectionId, label = "立即安装" } = Astro.props as Props;
---

<a id="topbar-install-cta" href={`#${installSectionId}`} data-smooth-scroll aria-hidden="true" tabindex="-1" class="apple-button apple-button--primary pointer-events-none h-10 px-4 text-sm font-semibold opacity-0 transition-opacity duration-300 ease-out sm:h-11 sm:px-5 sm:text-base">
  {label}
</a>
<button type="button" id="topbar-menu-toggle" data-topbar-menu-toggle aria-controls="topbar-nav-panel" aria-expanded="false" aria-label="展开导航菜单" class="inline-flex h-10 w-10 items-center justify-center rounded-[999px] border border-[var(--nav-border)] bg-[var(--control-bg)] text-[var(--nav-text)] md:hidden sm:h-11 sm:w-11">
  <Menu data-topbar-menu-icon="open" class="h-4 w-4" stroke-width={1.8} />
  <X data-topbar-menu-icon="close" class="hidden h-4 w-4" stroke-width={1.8} />
  <span class="sr-only">导航菜单</span>
</button>
