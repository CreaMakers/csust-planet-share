---
import { CodeXml, ExternalLink, Server, Smartphone } from "@lucide/astro";
import { siAndroid, siGithub, siSwift } from "simple-icons";
import type { PlatformKind, SourceOrganization, SourceProject } from "../../data/shared";

interface Props {
  platform: PlatformKind;
  sectionId: string;
  organization: SourceOrganization;
  projects: readonly SourceProject[];
  descriptionSuffix: string;
  title?: string;
}

const { platform, sectionId, organization, projects, descriptionSuffix, title = "源代码" } = Astro.props as Props;

const isIOS = platform === "ios";
---

<section id={sectionId} class="apple-section apple-section--light w-full scroll-mt-28 py-20 md:py-28 sm:scroll-mt-32">
  <div class="apple-section__inner">
    <div class="mb-14 text-center md:mb-16">
      <h2 class="apple-section-title text-3xl md:text-5xl">{title}</h2>
      <p class="apple-body apple-body--muted mx-auto mt-5 max-w-2xl text-lg md:text-xl">
        来自
        <a href={organization.href} target="_blank" rel="noopener noreferrer" class="apple-link mx-1 inline-flex items-center gap-1 font-medium hover:underline">
          {organization.name}
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
            <path d={siGithub.path}></path>
          </svg>
        </a>
        {descriptionSuffix}
      </p>
    </div>

    <div class="apple-card-grid apple-card-grid--three gap-6">
      {
        projects.map((project) => (
          <a href={project.href} target="_blank" rel="noopener noreferrer" class="apple-card group rounded-3xl p-6">
            {project.icon === "client" ? (
              isIOS ? (
                <div class="mb-4 inline-flex rounded-2xl bg-[var(--control-bg)] p-3">
                  <Smartphone class="h-7 w-7 text-[var(--color-blue)]" aria-hidden="true" />
                </div>
              ) : (
                <div class="mb-4 inline-flex rounded-2xl bg-[var(--control-bg)] p-3">
                  <svg viewBox="0 0 24 24" class="h-7 w-7 text-[var(--color-blue)]" fill="currentColor" aria-hidden="true">
                    <path d={siAndroid.path} />
                  </svg>
                </div>
              )
            ) : project.icon === "backend" ? (
              <div class="mb-4 inline-flex rounded-2xl bg-[var(--control-bg)] p-3">
                <Server class="h-7 w-7 text-[var(--color-blue)]" aria-hidden="true" />
              </div>
            ) : isIOS ? (
              <div class="mb-4 inline-flex rounded-2xl bg-[var(--control-bg)] p-3">
                <svg viewBox="0 0 24 24" class="h-7 w-7 text-[var(--color-blue)]" fill="currentColor" aria-hidden="true">
                  <path d={siSwift.path} />
                </svg>
              </div>
            ) : (
              <div class="mb-4 inline-flex rounded-2xl bg-[var(--control-bg)] p-3">
                <CodeXml class="h-7 w-7 text-[var(--color-blue)]" aria-hidden="true" />
              </div>
            )}
            <h3 class="apple-title-3 text-xl">{project.title}</h3>
            <p class="apple-body apple-body--muted mt-2">{project.description}</p>
            <span class="apple-link mt-5 inline-flex items-center gap-1 text-sm font-medium">
              查看项目
              <ExternalLink class="h-4 w-4" aria-hidden="true" />
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
