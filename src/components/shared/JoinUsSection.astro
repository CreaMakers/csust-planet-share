---
import { FilePenLine } from "@lucide/astro";

interface Props {
  sectionId: string;
  formUrl: string;
  title?: string;
  description?: string;
  ctaLabel?: string;
}

const { sectionId, formUrl, title = "加入我们", description = "如果你对技术充满热情，希望为校园生活带来改变，欢迎加入 CreaMakers 团队。", ctaLabel = "填写加入表单" } = Astro.props as Props;
---

<section id={sectionId} class="w-full scroll-mt-28 bg-zinc-50 py-20 md:py-24 sm:scroll-mt-32">
  <div class="mx-auto w-full max-w-[90rem] px-4 sm:px-6">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-semibold tracking-tight text-zinc-900 md:text-5xl">{title}</h2>
      <p class="mx-auto mt-5 max-w-3xl text-lg text-zinc-600 md:text-xl">{description}</p>
      <a href={formUrl} target="_blank" rel="noopener noreferrer" class="mt-9 inline-flex h-12 items-center justify-center gap-2 rounded-full bg-blue-600 px-8 text-base font-semibold text-white hover:bg-blue-700">
        {ctaLabel}
        <FilePenLine class="h-5 w-5" aria-hidden="true" />
      </a>
    </div>
  </div>
</section>
