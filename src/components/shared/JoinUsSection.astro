---
import { FilePenLine } from "@lucide/astro";

interface Props {
  sectionId: string;
  formUrl: string;
  title?: string;
  description?: string;
  ctaLabel?: string;
}

const { sectionId, formUrl, title = "加入我们", description = "如果你对技术充满热情，希望为校园生活带来改变，欢迎加入 CreaMakers 团队。", ctaLabel = "填写加入表单" } = Astro.props as Props;
---

<section id={sectionId} class="apple-section apple-section--light w-full scroll-mt-28 py-20 md:py-24 sm:scroll-mt-32">
  <div class="apple-section__inner">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="apple-section-title text-3xl md:text-5xl">{title}</h2>
      <p class="apple-body apple-body--muted mx-auto mt-5 max-w-3xl text-lg md:text-xl">{description}</p>
      <a href={formUrl} target="_blank" rel="noopener noreferrer" class="apple-button apple-button--primary mt-9 px-8 text-base font-semibold">
        {ctaLabel}
        <FilePenLine class="h-5 w-5" aria-hidden="true" />
      </a>
    </div>
  </div>
</section>
