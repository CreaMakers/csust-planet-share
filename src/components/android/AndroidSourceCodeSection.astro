---
import { CodeXml, ExternalLink, Server } from "@lucide/astro";
import { siAndroid, siGithub } from "simple-icons";
import { sourceCodeSectionId, sourceOrganization, sourceProjects } from "../../data/android";
---

<section id={sourceCodeSectionId} class="w-full scroll-mt-28 border-y border-zinc-200/70 bg-white/70 py-20 md:py-28 sm:scroll-mt-32">
  <div class="mx-auto w-full max-w-[90rem] px-4 sm:px-6">
    <div class="mb-14 text-center md:mb-16">
      <h2 class="text-3xl font-semibold tracking-tight text-zinc-900 md:text-5xl">源代码</h2>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-zinc-600 md:text-xl">
        来自
        <a href={sourceOrganization.href} target="_blank" rel="noopener noreferrer" class="mx-1 inline-flex items-center gap-1 font-medium text-blue-700 hover:underline">
          {sourceOrganization.name}
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
            <path d={siGithub.path}></path>
          </svg>
        </a>
        组织下的开源项目。
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        sourceProjects.map((project) => (
          <a href={project.href} target="_blank" rel="noopener noreferrer" class="group rounded-3xl border border-zinc-200/80 bg-white/90 p-6 transition duration-200 hover:border-zinc-300 hover:shadow-md hover:shadow-zinc-200/50">
            {project.icon === "client" ? (
              <div class="mb-4 inline-flex rounded-2xl bg-emerald-50/80 p-3">
                <svg viewBox="0 0 24 24" class="h-7 w-7 text-emerald-500" fill="currentColor" aria-hidden="true">
                  <path d={siAndroid.path} />
                </svg>
              </div>
            ) : project.icon === "backend" ? (
              <div class="mb-4 inline-flex rounded-2xl bg-indigo-50/80 p-3">
                <Server class="h-7 w-7 text-indigo-500" aria-hidden="true" />
              </div>
            ) : (
              <div class="mb-4 inline-flex rounded-2xl bg-amber-50/80 p-3">
                <CodeXml class="h-7 w-7 text-amber-500" aria-hidden="true" />
              </div>
            )}
            <h3 class="text-xl font-semibold tracking-tight text-zinc-900">{project.title}</h3>
            <p class="mt-2 text-zinc-600">{project.description}</p>
            <span class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-blue-700">
              查看项目
              <ExternalLink class="h-4 w-4" aria-hidden="true" />
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
