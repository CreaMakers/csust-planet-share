---
import { Image } from "astro:assets";
import { ChevronDown } from "@lucide/astro";
import { appIconImage } from "../../data/assets";
import { heroSectionId, installOptionsSectionId } from "../../data/android";
---

<section id={heroSectionId} class="bg-gradient-to-b from-zinc-50 via-white to-zinc-100 text-center text-zinc-900">
  <div class="mx-auto flex min-h-[calc(100vh-5rem)] w-full max-w-[90rem] items-center justify-center px-4 py-16 sm:px-6">
    <div class="flex w-full max-w-6xl flex-col items-center">
      <Image src={appIconImage} alt="长理星球 Android 图标" width={192} height={192} densities={[1.5, 2, 3]} format="png" priority class="mt-10 h-32 w-32 object-contain sm:h-40 sm:w-40" />
      <h1 class="mt-8 flex flex-wrap items-baseline justify-center gap-x-4 gap-y-2 text-5xl font-semibold tracking-tight sm:gap-x-5 sm:text-7xl">
        <span>长理星球</span>
      </h1>
      <p class="mt-5 max-w-3xl text-xl text-zinc-600 sm:text-2xl">课表、成绩、电量与校园工具</p>
      <a id="hero-install-cta" href={`#${installOptionsSectionId}`} data-smooth-scroll class="mt-10 inline-flex h-14 items-center justify-center gap-2 rounded-[999px] bg-blue-600 px-10 text-lg font-semibold text-white hover:bg-blue-700">
        立即安装
        <ChevronDown class="h-6 w-6" aria-hidden="true" />
      </a>
    </div>
  </div>
</section>
