---
import { Menu, X } from "@lucide/astro";
import { installOptionsSectionId } from "../../data/android";
---

<a id="topbar-install-cta" href={`#${installOptionsSectionId}`} data-smooth-scroll aria-hidden="true" tabindex="-1" class="pointer-events-none inline-flex h-10 items-center justify-center rounded-[999px] bg-blue-600 px-4 text-sm font-semibold text-white opacity-0 shadow-sm shadow-blue-200/70 transition-opacity duration-300 ease-out hover:bg-blue-700 sm:h-11 sm:px-5 sm:text-base"> 立即安装 </a>
<button type="button" id="topbar-menu-toggle" data-topbar-menu-toggle aria-controls="topbar-nav-panel" aria-expanded="false" aria-label="展开导航菜单" class="inline-flex h-10 w-10 items-center justify-center rounded-[999px] border border-zinc-200/80 bg-white/85 text-zinc-700 shadow-sm shadow-zinc-200/40 transition-colors duration-200 hover:bg-zinc-100 hover:text-zinc-900 md:hidden sm:h-11 sm:w-11">
  <Menu data-topbar-menu-icon="open" class="h-4 w-4" stroke-width={1.8} />
  <X data-topbar-menu-icon="close" class="hidden h-4 w-4" stroke-width={1.8} />
  <span class="sr-only">导航菜单</span>
</button>
