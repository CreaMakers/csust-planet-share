---
import { pageSections } from "../../data/ios";
---

<nav aria-label="页面导航" class="hidden items-center gap-0.5 md:flex">
  {
    pageSections.map((section) => (
      <a href={`#${section.id}`} data-section-link data-smooth-scroll class="rounded-full px-2 py-1 text-sm font-medium text-zinc-500 transition-colors duration-200 hover:text-zinc-900">
        {section.label}
      </a>
    ))
  }
</nav>

<nav aria-label="移动端页面导航" class="flex flex-col gap-1 border-t border-zinc-200/70 pt-3 md:hidden">
  {
    pageSections.map((section) => (
      <a href={`#${section.id}`} data-section-link data-topbar-menu-link data-mobile-section-link data-smooth-scroll class="rounded-2xl px-4 py-3 text-sm font-medium text-zinc-500 transition-colors duration-200 hover:bg-zinc-100 hover:text-zinc-900">
        {section.label}
      </a>
    ))
  }
</nav>
