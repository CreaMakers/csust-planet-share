---
import { ChevronDown } from "@lucide/astro";
import { familyImage } from "../../data/assets";
import { heroSectionId, installOptionsSectionId } from "../../data/ios";
import SmartImage from "../shared/SmartImage.astro";
---

<section id={heroSectionId} class="apple-section apple-section--light text-center">
  <div class="apple-section__inner apple-hero">
    <div class="flex w-full max-w-6xl flex-col items-center">
      <h1 class="apple-display flex flex-wrap items-baseline justify-center gap-x-4 gap-y-2 sm:gap-x-5">
        <span>长理星球</span>
        <span class="text-4xl text-[var(--color-blue)] sm:text-6xl">for Apple</span>
      </h1>
      <p class="apple-body apple-body--muted mt-5 max-w-3xl text-xl sm:text-2xl">课表、成绩、电量与校园工具，多端原生支持的校园助手</p>
      <SmartImage
        src={familyImage}
        alt="长理星球 iOS 页面展示图"
        widths={[768, 1024, 1280, 1536, 2048]}
        sizes="(min-width: 1280px) 64rem, (min-width: 640px) calc(100vw - 3rem), calc(100vw - 2rem)"
        priority
        wrapperClass="mt-10 w-full max-w-5xl"
        imageClass="w-full object-contain"
        radiusClass="rounded-[2rem]"
        skeletonClass="bg-[color-mix(in_srgb,var(--image-skeleton-base)_80%,transparent)]"
      />
      <a id="hero-install-cta" href={`#${installOptionsSectionId}`} data-smooth-scroll class="apple-button apple-button--primary mt-10 px-10 text-lg font-semibold">
        立即安装
        <ChevronDown class="h-6 w-6" aria-hidden="true" />
      </a>
    </div>
  </div>
</section>
