---
import { Image } from "astro:assets";
import { desktopFeatureImageSizes, featureImageWidths, featurePlatforms, featureSectionHeight, featureSlides } from "../../data/ios";
---

<div data-feature-showcase-desktop class="relative hidden lg:block" style={`height: ${featureSectionHeight};`}>
  <div class="sticky top-0 box-border h-screen px-4 pt-24 sm:px-6 sm:pt-28">
    <div class="mx-auto flex h-full w-full max-w-[90rem] items-center gap-12">
      <div class="flex h-full w-[24rem] shrink-0 flex-col justify-center">
        <div class="relative min-h-[18rem]">
          {
            featureSlides.map((slide, index) => (
              <article data-feature-copy aria-hidden={index === 0 ? "false" : "true"} class:list={["absolute inset-0 flex max-w-xl flex-col justify-center transition-opacity duration-500 ease-out", index === 0 ? "opacity-100" : "pointer-events-none opacity-0"]}>
                <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-blue)]">FEATURE {String(index + 1).padStart(2, "0")}</p>
                <h2 class="apple-section-title mt-5 text-5xl text-[var(--page-text)]">{slide.title}</h2>
                <p class="apple-body mt-6 text-2xl leading-relaxed text-[var(--page-muted)]">{slide.description}</p>
              </article>
            ))
          }
        </div>

        <div class="apple-pill-switcher mt-10 overflow-hidden">
          <span id="feature-platform-indicator" aria-hidden="true" class="absolute left-1 top-1 h-11 w-24 rounded-full bg-[var(--control-active-bg)] transition-transform duration-300 ease-out xl:w-28"></span>
          {
            featurePlatforms.map((platform, index) => (
              <button type="button" data-feature-platform-button data-platform={platform.id} data-platform-index={index} aria-pressed={index === 0 ? "true" : "false"} class:list={["relative z-10 inline-flex h-11 w-24 shrink-0 items-center justify-center rounded-full px-0 text-base font-medium transition-colors duration-300 xl:w-28", index === 0 ? "text-[var(--control-active-text)]" : "text-[var(--control-text)] hover:text-[var(--page-text)]"]}>
                {platform.label}
              </button>
            ))
          }
        </div>
      </div>

      <div class="relative h-full min-w-0 flex-1">
        {
          featureSlides.map((slide, slideIndex) =>
            featurePlatforms.map((platform, platformIndex) => (
              <div data-feature-visual data-slide-index={slideIndex} data-platform={platform.id} aria-hidden={slideIndex === 0 && platformIndex === 0 ? "false" : "true"} class:list={["absolute inset-0 flex items-center justify-end transition-opacity duration-500 ease-out", slideIndex === 0 && platformIndex === 0 ? "opacity-100" : "pointer-events-none opacity-0"]}>
                <Image src={slide.images[platform.id]} alt={`${slide.title}${platform.label}界面`} widths={featureImageWidths[platform.id]} sizes={desktopFeatureImageSizes[platform.id]} class={`object-contain ${platform.imageClass}`} />
              </div>
            )),
          )
        }
      </div>
    </div>
  </div>
</div>
