---
import AppLayout from "../../layouts/AppLayout.astro";

const title = "长理星球 | iOS 支持与反馈";
const description = "长理星球 iOS 客户端的支持与反馈页面。";
const feedbackUrl = "https://my.feishu.cn/share/base/form/shrcnmYT0Hn0MEWoV11cnfi7zHg";
---

<AppLayout title={title} description={description}>
  <section class="apple-section apple-section--light apple-info-page">
    <div class="apple-info-shell">
      <p class="apple-info-eyebrow">Support</p>
      <h1 class="apple-section-title mt-3">iOS 支持与反馈</h1>
      <p class="apple-info-lead">感谢您使用长理星球 iOS 客户端。如果您在使用过程中遇到任何问题，或者有任何建议，欢迎通过以下方式与我们联系。</p>

      <div class="apple-info-stack">
        <section class="apple-info-block">
          <div class="apple-info-block__title">
            <h2 class="apple-title-3">联系开发者</h2>
          </div>
          <div class="apple-info-block__content">
            <p class="apple-body apple-body--muted">您可以通过发送邮件直接联系开发者。为了更快地解决您的问题，请在邮件中尽可能包含您的设备型号、系统版本以及问题的详细描述。</p>
            <div class="mt-6">
              <p class="text-sm font-semibold tracking-[-0.224px] text-[var(--page-soft)]">开发者邮箱</p>
              <p class="mt-2 text-[1.3125rem] font-semibold leading-[1.19] tracking-[0.231px] text-[var(--page-text)]">developer[at]zhelearn.com</p>
            </div>
          </div>
        </section>

        <section class="apple-info-block">
          <div class="apple-info-block__title">
            <h2 class="apple-title-3">填写意见反馈表单</h2>
          </div>
          <div class="apple-info-block__content">
            <p class="apple-body apple-body--muted">您也可以通过填写我们的意见反馈表单来提交您的建议或报告遇到的 Bug。我们会定期查看并处理表单中的反馈。</p>
            <div class="mt-8">
              <a href={feedbackUrl} target="_blank" rel="noopener noreferrer" class="apple-button apple-button--secondary">
                前往填写反馈表单
              </a>
            </div>
          </div>
        </section>
      </div>
    </div>
  </section>
</AppLayout>
