---
import AppLayout from "../../layouts/AppLayout.astro";
import UserAgreementDocument from "../../content/documents/UserAgreement.md";

const title = "长理星球 | iOS 用户协议";
const description = "长理星球 iOS 客户端用户协议。";
---

<AppLayout title={title} description={description}>
  <section class="apple-section apple-section--light apple-info-page">
    <div class="apple-info-shell apple-info-shell--narrow">
      <article class="apple-doc">
        <UserAgreementDocument />
      </article>
    </div>
  </section>
</AppLayout>
