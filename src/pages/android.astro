---
import AndroidHeroSection from "../components/android/AndroidHeroSection.astro";
import AndroidPageScripts from "../components/android/AndroidPageScripts.astro";
import InstallOptionsSection from "../components/shared/InstallOptionsSection.astro";
import JoinUsSection from "../components/shared/JoinUsSection.astro";
import PlatformPageLayout from "../components/shared/PlatformPageLayout.astro";
import SourceCodeSection from "../components/shared/SourceCodeSection.astro";
import { createInstallOptions, installOptionsSectionId, joinUsFormUrl, joinUsSectionId, pageDescription, pageSections, pageTitle, sourceCodeSectionId, sourceOrganization, sourceProjects } from "../data/android";
import { readAndroidApkUrl } from "../lib/app-config";

const androidApkUrl = await readAndroidApkUrl();
---

<PlatformPageLayout title={pageTitle} description={pageDescription} sections={pageSections} installSectionId={installOptionsSectionId}>
  <AndroidHeroSection />
  <InstallOptionsSection sectionId={installOptionsSectionId} options={createInstallOptions(androidApkUrl)} />
  <SourceCodeSection platform="android" sectionId={sourceCodeSectionId} organization={sourceOrganization} projects={sourceProjects} descriptionSuffix="组织下的开源项目。" />
  <JoinUsSection sectionId={joinUsSectionId} formUrl={joinUsFormUrl} />
  <AndroidPageScripts />
</PlatformPageLayout>
