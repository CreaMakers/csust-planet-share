---
import AppLayout from "../layouts/AppLayout.astro";
import IosFeatureShowcaseSection from "../components/ios/IosFeatureShowcaseSection.astro";
import IosHeaderNav from "../components/ios/IosHeaderNav.astro";
import IosHeroSection from "../components/ios/IosHeroSection.astro";
import IosInstallOptionsSection from "../components/ios/IosInstallOptionsSection.astro";
import IosJoinUsSection from "../components/ios/IosJoinUsSection.astro";
import IosPageScripts from "../components/ios/IosPageScripts.astro";
import IosSourceCodeSection from "../components/ios/IosSourceCodeSection.astro";
import IosTopbarInstallButton from "../components/ios/IosTopbarInstallButton.astro";
import { appIconImage } from "../data/assets";
import { pageDescription, pageTitle } from "../data/ios";

const pageUrl = Astro.url.href;
const previewImageUrl = new URL(appIconImage.src, Astro.url).href;
---

<AppLayout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={pageUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="长理星球" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:image" content={previewImageUrl} />
    <meta property="og:image:alt" content="长理星球应用图标" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={previewImageUrl} />
  </Fragment>

  <IosHeaderNav slot="header-nav" />
  <IosTopbarInstallButton slot="header-actions" />

  <IosHeroSection />
  <IosFeatureShowcaseSection />
  <IosInstallOptionsSection />
  <IosSourceCodeSection />
  <IosJoinUsSection />
  <IosPageScripts />
</AppLayout>
