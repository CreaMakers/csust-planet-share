---
import IosFeatureShowcaseSection from "../components/ios/IosFeatureShowcaseSection.astro";
import IosHeroSection from "../components/ios/IosHeroSection.astro";
import IosPageScripts from "../components/ios/IosPageScripts.astro";
import InstallOptionsSection from "../components/shared/InstallOptionsSection.astro";
import JoinUsSection from "../components/shared/JoinUsSection.astro";
import PlatformPageLayout from "../components/shared/PlatformPageLayout.astro";
import SourceCodeSection from "../components/shared/SourceCodeSection.astro";
import { installOptions, installOptionsSectionId, joinUsFormUrl, joinUsSectionId, pageDescription, pageSections, pageTitle, sourceCodeSectionId, sourceOrganization, sourceProjects } from "../data/ios";
---

<PlatformPageLayout title={pageTitle} description={pageDescription} sections={pageSections} installSectionId={installOptionsSectionId}>
  <IosHeroSection />
  <IosFeatureShowcaseSection />
  <InstallOptionsSection sectionId={installOptionsSectionId} options={installOptions} />
  <SourceCodeSection platform="ios" sectionId={sourceCodeSectionId} organization={sourceOrganization} projects={sourceProjects} descriptionSuffix="组织下的 MIT 协议开源项目。" />
  <JoinUsSection sectionId={joinUsSectionId} formUrl={joinUsFormUrl} />
  <IosPageScripts />
</PlatformPageLayout>
