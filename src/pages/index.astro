---
import AppLayout from "../layouts/AppLayout.astro";
import { ArrowRight } from "@lucide/astro";
import { siAndroid, siApple } from "simple-icons";

const userAgent = (Astro.request.headers.get("user-agent") ?? "").toLowerCase();
const isIOS = /(iphone|ipad|ipod|ios)/.test(userAgent) || (userAgent.includes("macintosh") && userAgent.includes("mobile"));
const isAndroid = userAgent.includes("android");
const pageTitle = "长理星球";
const pageDescription = "长理星球下载入口。系统会自动识别跳转，也可手动选择 iOS 或 Android 版本。";

if (isIOS) {
  return Astro.redirect("/ios", 302);
}

if (isAndroid) {
  return Astro.redirect("/android", 302);
}
---

<AppLayout title={pageTitle} description={pageDescription}>
  <section class="flex flex-1">
    <div class="mx-auto flex h-full min-h-0 w-full max-w-[90rem] flex-1 flex-col items-center justify-center px-4 py-8 text-center sm:px-6 sm:py-10">
      <img src="/logo_transparent.png" alt="长理星球" class="h-28 w-28 rounded-3xl object-contain ring-1 ring-zinc-200 shadow-xl shadow-zinc-300/40 sm:h-36 sm:w-36" />
      <h1 class="mt-6 text-4xl font-semibold tracking-tight sm:text-6xl">长理星球</h1>
      <p class="mt-4 max-w-2xl text-base text-zinc-600 sm:text-lg">校园生活服务入口。你可以手动选择平台继续下载。</p>

      <div class="mt-8 grid w-full max-w-xl grid-cols-1 gap-4 sm:grid-cols-2">
        <a href="/android" class="inline-flex h-14 items-center justify-center gap-2 rounded-full border border-blue-200 bg-blue-50 px-6 text-base font-semibold text-blue-700">
          <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="currentColor" aria-hidden="true">
            <path d={siAndroid.path}></path>
          </svg>
          Android 端下载
          <ArrowRight class="h-4 w-4" aria-hidden="true" />
        </a>
        <a href="/ios" class="inline-flex h-14 items-center justify-center gap-2 rounded-full border border-blue-200 bg-blue-50 px-6 text-base font-semibold text-blue-700">
          <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="currentColor" aria-hidden="true">
            <path d={siApple.path}></path>
          </svg>
          iOS 端下载
          <ArrowRight class="h-4 w-4" aria-hidden="true" />
        </a>
      </div>
    </div>
  </section>
</AppLayout>
