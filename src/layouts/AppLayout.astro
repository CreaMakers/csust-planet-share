---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "长理星球", description = "长理星球官方页面" } = Astro.props;
---

<html lang="zh-CN" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f8fafc" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#09090b" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-zinc-50 text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100">
    <div class="flex min-h-screen flex-col">
      <header class="fixed inset-x-0 top-0 z-50 px-4 pt-4 sm:px-6 sm:pt-6">
        <div class="mx-auto flex h-16 w-full max-w-5xl items-center rounded-2xl border border-zinc-200/80 bg-white/75 px-4 shadow-sm shadow-zinc-200/40 backdrop-blur-md dark:border-zinc-800/80 dark:bg-zinc-900/70 dark:shadow-zinc-950/60">
          <a href="/" class="inline-flex items-center gap-3">
            <img src="/logo_transparent.png" alt="长理星球 Logo" class="h-10 w-10 object-contain" />
            <span class="text-lg font-semibold tracking-tight sm:text-xl"> 长理星球 </span>
          </a>
        </div>
      </header>

      <main class="flex min-h-0 flex-1 flex-col pt-20 sm:pt-24">
        <slot />
      </main>

      <footer class="border-t border-zinc-200/80 bg-white/80 py-5 text-center text-sm text-zinc-500 backdrop-blur-md dark:border-zinc-800 dark:bg-zinc-900/70 dark:text-zinc-400">&copy; 2024-2026 CreaMakers</footer>
    </div>
  </body>
</html>
