---
import "../styles/global.css";
import { appIconImage } from "../data/assets";
import { androidSourceLinks, communityLinks, createAndroidPrimaryLinks, defaultLayoutDescription, defaultLayoutTitle, footerBrand, iosPrimaryLinks, iosSourceLinks } from "../data/app-layout";
import SmartImage from "../components/shared/SmartImage.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title = defaultLayoutTitle, description = defaultLayoutDescription } = Astro.props;
const hasHeaderNav = Astro.slots.has("header-nav");
const hasHeaderActions = Astro.slots.has("header-actions");
const androidPrimaryLinks = createAndroidPrimaryLinks("#");
const umamiScriptUrl = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL;
const umamiRecorderScriptUrl = import.meta.env.PUBLIC_UMAMI_RECORDER_SCRIPT_URL;
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const umamiRecorderSampleRate = import.meta.env.PUBLIC_UMAMI_RECORDER_SAMPLE_RATE;
const umamiRecorderMaskLevel = import.meta.env.PUBLIC_UMAMI_RECORDER_MASK_LEVEL;
const umamiRecorderMaxDuration = import.meta.env.PUBLIC_UMAMI_RECORDER_MAX_DURATION;
const shouldLoadUmami = Boolean(umamiScriptUrl && umamiWebsiteId);
const shouldLoadUmamiRecorder = Boolean(umamiRecorderScriptUrl && umamiWebsiteId);
---

<html lang="zh-CN" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#f5f5f7" />
    <title>{title}</title>
    <slot name="head" />
    {shouldLoadUmami && <script is:inline defer src={umamiScriptUrl} data-website-id={umamiWebsiteId} />}
    {shouldLoadUmamiRecorder && <script is:inline defer src={umamiRecorderScriptUrl} data-website-id={umamiWebsiteId} data-sample-rate={umamiRecorderSampleRate} data-mask-level={umamiRecorderMaskLevel} data-max-duration={umamiRecorderMaxDuration} />}
    <script is:inline>
      (() => {
        const storageKey = "csust-theme-mode";
        const root = document.documentElement;
        const metaThemeColor = document.querySelector('meta[name="theme-color"]');
        const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
        const getStoredPreference = () => {
          try {
            return localStorage.getItem(storageKey) ?? "system";
          } catch {
            return "system";
          }
        };
        const applyTheme = (preference) => {
          const resolvedTheme = preference === "system" ? (mediaQuery.matches ? "dark" : "light") : preference;
          root.dataset.themePreference = preference;
          root.dataset.theme = resolvedTheme;
          metaThemeColor?.setAttribute("content", resolvedTheme === "dark" ? "#000000" : "#f5f5f7");
        };
        applyTheme(getStoredPreference());
      })();
    </script>
  </head>
  <body class="apple-page min-h-screen antialiased">
    <div class="flex min-h-screen flex-col">
      <header class="fixed inset-x-0 top-0 z-50 px-5 pt-4 sm:px-8 sm:pt-6 lg:px-10">
        <div data-topbar-shell data-topbar-expanded="false" class="apple-nav-surface mx-auto grid min-h-16 w-full max-w-[54rem] grid-cols-[auto_1fr_auto] grid-rows-[3rem_auto] items-center rounded-[2rem] border px-4 py-2 transition-[padding,row-gap] duration-300 sm:px-5 md:grid-rows-1 md:rounded-full md:px-6 md:py-0">
          <a href="/" class="col-start-1 row-start-1 inline-flex min-w-0 items-center gap-3">
            <SmartImage src={appIconImage} alt="长理星球 Logo" width={40} height={40} densities={[1.5, 2, 3]} priority wrapperClass="h-10 w-10 shrink-0" imageClass="h-full w-full object-contain" radiusClass="" skeletonClass="bg-[color-mix(in_srgb,var(--image-skeleton-base)_92%,transparent)]" />
            <span class="truncate text-lg font-semibold tracking-tight sm:text-xl">长理星球</span>
          </a>
          {
            hasHeaderNav && (
              <div id="topbar-nav-panel" data-topbar-nav-panel class="col-span-3 row-start-2 min-w-0 md:col-span-1 md:col-start-2 md:row-start-1 md:flex md:justify-center">
                <slot name="header-nav" />
              </div>
            )
          }
          {
            hasHeaderActions && (
              <div class="col-start-3 row-start-1 flex shrink-0 items-center justify-end gap-2">
                <slot name="header-actions" />
              </div>
            )
          }
        </div>
      </header>

      <main class="flex min-h-0 flex-1 flex-col pt-20 sm:pt-24">
        <slot />
      </main>

      <footer class="apple-footer py-14 text-sm">
        <div class="mx-auto grid w-full max-w-[90rem] grid-cols-2 gap-10 px-4 sm:px-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)_minmax(0,0.85fr)_minmax(0,0.7fr)] lg:gap-12">
          <div class="col-span-2 max-w-xl lg:col-span-1">
            <p class="text-sm font-semibold text-[var(--color-blue)]">{footerBrand.eyebrow}</p>
            <div class="mt-5 flex items-center gap-4">
              <SmartImage src={footerBrand.iconSrc} alt={footerBrand.iconAlt} width={48} height={48} densities={[1.5, 2, 3]} wrapperClass="h-12 w-12 shrink-0" imageClass="h-full w-full object-cover" radiusClass="" skeletonClass="bg-[color-mix(in_srgb,var(--image-skeleton-base)_92%,transparent)]" />
              <p class="text-2xl font-semibold tracking-tight text-[var(--page-text)]">{footerBrand.title}</p>
            </div>
            <p class="mt-4 leading-7 text-[var(--page-muted)]">{footerBrand.description}</p>
            <div class="mt-6 space-y-2 text-[var(--page-soft)]">
              {footerBrand.legalLines.map((line) => <p>{line}</p>)}
            </div>
          </div>

          <div>
            <p class="text-sm font-semibold text-[var(--page-soft)]">iOS 端</p>
            <ul class="mt-5 space-y-3">
              {
                iosPrimaryLinks.map((link) => (
                  <li>
                    <a href={link.href} class="transition-colors duration-200 hover:text-[var(--page-text)]">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
            <ul class="mt-5 space-y-3 border-t border-[var(--footer-border)] pt-5">
              {
                iosSourceLinks.map((link) => (
                  <li>
                    <a href={link.href} class="transition-colors duration-200 hover:text-[var(--page-text)]">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div>
            <p class="text-sm font-semibold text-[var(--page-soft)]">Android 端</p>
            <ul class="mt-5 space-y-3">
              {
                androidPrimaryLinks.map((link) => (
                  <li>
                    <a href={link.href} data-android-download-link={link.label === "Android 下载" ? "true" : undefined} class="transition-colors duration-200 hover:text-[var(--page-text)]">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
            <ul class="mt-5 space-y-3 border-t border-[var(--footer-border)] pt-5">
              {
                androidSourceLinks.map((link) => (
                  <li>
                    <a href={link.href} class="transition-colors duration-200 hover:text-[var(--page-text)]">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="col-span-2 lg:col-span-1">
            <p class="text-sm font-semibold text-[var(--page-soft)]">社区</p>
            <ul class="mt-5 space-y-3">
              {
                communityLinks.map((link) => (
                  <li>
                    <a href={link.href} class="transition-colors duration-200 hover:text-[var(--page-text)]">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="col-span-2 flex flex-col items-start gap-3 border-t border-[var(--footer-border)] pt-8 lg:col-span-4 lg:flex-row lg:items-center lg:justify-between">
            <p class="text-sm text-[var(--page-soft)]">外观</p>
            <div class="apple-pill-switcher" role="group" aria-label="外观切换">
              <button type="button" class="apple-pill-switcher__button" data-theme-toggle="light">浅色</button>
              <button type="button" class="apple-pill-switcher__button" data-theme-toggle="dark">深色</button>
              <button type="button" class="apple-pill-switcher__button" data-theme-toggle="system">跟随系统</button>
            </div>
          </div>
        </div>
      </footer>
    </div>
    <script is:inline>
      (() => {
        const storageKey = "csust-theme-mode";
        const root = document.documentElement;
        const themeButtons = Array.from(document.querySelectorAll("[data-theme-toggle]"));
        const metaThemeColor = document.querySelector('meta[name="theme-color"]');
        const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
        const getPreference = () => root.dataset.themePreference ?? "system";
        const resolveTheme = (preference) => (preference === "system" ? (mediaQuery.matches ? "dark" : "light") : preference);
        const syncButtons = (preference) => {
          themeButtons.forEach((button) => {
            const isActive = button instanceof HTMLElement && button.dataset.themeToggle === preference;
            button.setAttribute("data-active", String(isActive));
            button.setAttribute("aria-pressed", String(isActive));
          });
        };
        const applyTheme = (preference, persist) => {
          const resolvedTheme = resolveTheme(preference);
          root.dataset.themePreference = preference;
          root.dataset.theme = resolvedTheme;
          metaThemeColor?.setAttribute("content", resolvedTheme === "dark" ? "#000000" : "#f5f5f7");
          syncButtons(preference);
          if (!persist) {
            return;
          }
          try {
            localStorage.setItem(storageKey, preference);
          } catch {}
        };

        syncButtons(getPreference());

        themeButtons.forEach((button) => {
          button.addEventListener("click", () => {
            if (!(button instanceof HTMLElement)) {
              return;
            }
            const preference = button.dataset.themeToggle;
            if (preference === "light" || preference === "dark" || preference === "system") {
              applyTheme(preference, true);
            }
          });
        });

        const handleSystemChange = () => {
          if (getPreference() === "system") {
            applyTheme("system", false);
          }
        };

        if (typeof mediaQuery.addEventListener === "function") {
          mediaQuery.addEventListener("change", handleSystemChange);
        } else {
          mediaQuery.addListener(handleSystemChange);
        }
      })();
    </script>
  </body>
</html>

<style>
  [data-topbar-shell] {
    row-gap: 0;
  }

  [data-topbar-nav-panel] {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transition:
      max-height 240ms ease,
      opacity 180ms ease;
  }

  @media (max-width: 767px) {
    [data-topbar-shell][data-topbar-expanded="true"] {
      row-gap: 0.75rem;
      padding-bottom: 1rem;
    }

    [data-topbar-shell][data-topbar-expanded="true"] [data-topbar-nav-panel] {
      max-height: 20rem;
      opacity: 1;
      pointer-events: auto;
      visibility: visible;
    }
  }

  @media (min-width: 768px) {
    [data-topbar-nav-panel] {
      max-height: none;
      overflow: visible;
      opacity: 1;
      pointer-events: auto;
      visibility: visible;
    }
  }
</style>
