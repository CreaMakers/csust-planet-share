---
import "../styles/global.css";
import { readFile } from "node:fs/promises";
import { resolve } from "node:path";

interface Props {
  title?: string;
  description?: string;
}

type AppConfig = {
  apkUrl?: string;
};

const readAppConfig = async (): Promise<AppConfig> => {
  const configPaths = [resolve(process.cwd(), "config/config.json"), resolve(process.cwd(), "config/config.template.json")];

  for (const configPath of configPaths) {
    try {
      const configContent = await readFile(configPath, "utf-8");
      return JSON.parse(configContent) as AppConfig;
    } catch {
      continue;
    }
  }

  return {};
};

const { title = "长理星球", description = "长理星球官方页面" } = Astro.props;
const hasHeaderNav = Astro.slots.has("header-nav");
const hasHeaderActions = Astro.slots.has("header-actions");
const { apkUrl = "#" } = await readAppConfig();

const iosPrimaryLinks = [
  { label: "iOS 页面", href: "/ios" },
  { label: "App Store", href: "https://apps.apple.com/zh/app/%E9%95%BF%E7%90%86%E6%98%9F%E7%90%83/id6748840801" },
  { label: "TestFlight", href: "https://testflight.apple.com/join/xMbzN8aU" },
  { label: "意见反馈", href: "https://my.feishu.cn/share/base/form/shrcnmYT0Hn0MEWoV11cnfi7zHg" },
];

const iosSourceLinks = [
  { label: "iOS App 开源", href: "https://github.com/zHElEARN/CSUSTPlanet" },
  { label: "iOS 后端开源", href: "https://github.com/zHElEARN/go-csust-planet" },
  { label: "iOS 网络库开源", href: "https://github.com/zHElEARN/CSUSTKit" },
];

const androidPrimaryLinks = [
  { label: "Android 页面", href: "/android" },
  { label: "Android 下载", href: apkUrl },
  { label: "意见反馈", href: "https://creamaker.feishu.cn/share/base/form/shrcn6LjBK78JLJfLeKDMe3hczd?chunked=false" },
];

const androidSourceLinks = [
  { label: "Android App 开源", href: "https://github.com/CreaMakers/changli-planet-app" },
  { label: "Android 后端开源", href: "https://github.com/CreaMakers/changli-planet-backend" },
  { label: "Android 网络库开源", href: "https://github.com/CreaMakers/CSUSTDataGet" },
];

const communityLinks = [{ label: "QQ 交流群", href: "mqqapi://card/show_pslcard?src_type=internal&version=1&uin=125010161&key=&card_type=group&source=external" }];
---

<html lang="zh-CN" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#f8fafc" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-zinc-50 text-zinc-900 antialiased">
    <div class="flex min-h-screen flex-col">
      <header class="fixed inset-x-0 top-0 z-50 px-5 pt-4 sm:px-8 sm:pt-6 lg:px-10">
        <div class="mx-auto grid h-16 w-full max-w-[54rem] grid-cols-[auto_1fr_auto] items-center gap-4 rounded-full border border-zinc-200/80 bg-white/60 px-5 shadow-sm shadow-zinc-200/40 backdrop-blur-md sm:px-6">
          <a href="/" class="inline-flex items-center gap-3">
            <img src="/Logo.png" alt="长理星球 Logo" class="h-10 w-10 object-contain" />
            <span class="text-lg font-semibold tracking-tight sm:text-xl"> 长理星球 </span>
          </a>
          {
            hasHeaderNav && (
              <div class="flex min-w-0 justify-center">
                <slot name="header-nav" />
              </div>
            )
          }
          {
            hasHeaderActions && (
              <div class="flex shrink-0 items-center justify-end">
                <slot name="header-actions" />
              </div>
            )
          }
        </div>
      </header>

      <main class="flex min-h-0 flex-1 flex-col pt-20 sm:pt-24">
        <slot />
      </main>

      <footer class="border-t border-zinc-200/80 bg-white/85 py-14 text-sm text-zinc-600 backdrop-blur-md">
        <div class="mx-auto grid w-full max-w-[90rem] grid-cols-2 gap-10 px-4 sm:px-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)_minmax(0,0.85fr)_minmax(0,0.7fr)] lg:gap-12">
          <div class="col-span-2 max-w-xl lg:col-span-1">
            <p class="text-sm font-semibold text-blue-600">版权声明</p>
            <div class="mt-5 flex items-center gap-4">
              <img src="/Apple/AppIcon.png" alt="长理星球 App Icon" class="h-12 w-12 object-cover" />
              <p class="text-2xl font-semibold tracking-tight text-zinc-900">长理星球</p>
            </div>
            <p class="mt-4 leading-7 text-zinc-600">长理星球为社区开发项目，并非长沙理工大学官方产品。长沙理工大学相关校名、校徽与标识权利归长沙理工大学所有。</p>
            <div class="mt-6 space-y-2 text-zinc-500">
              <p>&copy; 2024-2026 CreaMakers</p>
              <p>湘ICP备2024091230号-2</p>
            </div>
          </div>

          <div>
            <p class="text-sm font-semibold text-zinc-500">iOS 端</p>
            <ul class="mt-5 space-y-3">
              {
                iosPrimaryLinks.map((link) => (
                  <li>
                    <a href={link.href} class="transition-colors duration-200 hover:text-zinc-900">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
            <ul class="mt-5 space-y-3 border-t border-zinc-200 pt-5">
              {
                iosSourceLinks.map((link) => (
                  <li>
                    <a href={link.href} class="transition-colors duration-200 hover:text-zinc-900">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div>
            <p class="text-sm font-semibold text-zinc-500">Android 端</p>
            <ul class="mt-5 space-y-3">
              {
                androidPrimaryLinks.map((link) => (
                  <li>
                    <a href={link.href} class="transition-colors duration-200 hover:text-zinc-900">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
            <ul class="mt-5 space-y-3 border-t border-zinc-200 pt-5">
              {
                androidSourceLinks.map((link) => (
                  <li>
                    <a href={link.href} class="transition-colors duration-200 hover:text-zinc-900">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="col-span-2 lg:col-span-1">
            <p class="text-sm font-semibold text-zinc-500">社区</p>
            <ul class="mt-5 space-y-3">
              {
                communityLinks.map((link) => (
                  <li>
                    <a href={link.href} class="transition-colors duration-200 hover:text-zinc-900">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
