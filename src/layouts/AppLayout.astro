---
import "../styles/global.css";
import { readFile } from "node:fs/promises";
import { resolve } from "node:path";
import { androidSourceLinks, communityLinks, createAndroidPrimaryLinks, defaultLayoutDescription, defaultLayoutTitle, footerBrand, iosPrimaryLinks, iosSourceLinks } from "../data/app-layout";

interface Props {
  title?: string;
  description?: string;
}

type AppConfig = {
  apkUrl?: string;
};

const readAppConfig = async (): Promise<AppConfig> => {
  const configPaths = [resolve(process.cwd(), "config/config.json"), resolve(process.cwd(), "config/config.template.json")];

  for (const configPath of configPaths) {
    try {
      const configContent = await readFile(configPath, "utf-8");
      return JSON.parse(configContent) as AppConfig;
    } catch {
      continue;
    }
  }

  return {};
};

const { title = defaultLayoutTitle, description = defaultLayoutDescription } = Astro.props;
const hasHeaderNav = Astro.slots.has("header-nav");
const hasHeaderActions = Astro.slots.has("header-actions");
const { apkUrl = "#" } = await readAppConfig();
const androidPrimaryLinks = createAndroidPrimaryLinks(apkUrl);
---

<html lang="zh-CN" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#f8fafc" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-zinc-50 text-zinc-900 antialiased">
    <div class="flex min-h-screen flex-col">
      <header class="fixed inset-x-0 top-0 z-50 px-5 pt-4 sm:px-8 sm:pt-6 lg:px-10">
        <div data-topbar-shell data-topbar-expanded="false" class="mx-auto grid min-h-16 w-full max-w-[54rem] grid-cols-[auto_1fr_auto] grid-rows-[3rem_auto] items-center rounded-[2rem] border border-zinc-200/80 bg-white/60 px-4 py-2 shadow-sm shadow-zinc-200/40 backdrop-blur-md transition-[padding,row-gap] duration-300 sm:px-5 md:grid-rows-1 md:rounded-full md:px-6 md:py-0">
          <a href="/" class="col-start-1 row-start-1 inline-flex min-w-0 items-center gap-3">
            <img src="/Logo.png" alt="长理星球 Logo" class="h-10 w-10 object-contain" />
            <span class="truncate text-lg font-semibold tracking-tight sm:text-xl"> 长理星球 </span>
          </a>
          {
            hasHeaderNav && (
              <div id="topbar-nav-panel" data-topbar-nav-panel class="col-span-3 row-start-2 min-w-0 md:col-span-1 md:col-start-2 md:row-start-1 md:flex md:justify-center">
                <slot name="header-nav" />
              </div>
            )
          }
          {
            hasHeaderActions && (
              <div class="col-start-3 row-start-1 flex shrink-0 items-center justify-end gap-2">
                <slot name="header-actions" />
              </div>
            )
          }
        </div>
      </header>

      <main class="flex min-h-0 flex-1 flex-col pt-20 sm:pt-24">
        <slot />
      </main>

      <footer class="border-t border-zinc-200/80 bg-white/85 py-14 text-sm text-zinc-600 backdrop-blur-md">
        <div class="mx-auto grid w-full max-w-[90rem] grid-cols-2 gap-10 px-4 sm:px-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)_minmax(0,0.85fr)_minmax(0,0.7fr)] lg:gap-12">
          <div class="col-span-2 max-w-xl lg:col-span-1">
            <p class="text-sm font-semibold text-blue-600">{footerBrand.eyebrow}</p>
            <div class="mt-5 flex items-center gap-4">
              <img src={footerBrand.iconSrc} alt={footerBrand.iconAlt} class="h-12 w-12 object-cover" />
              <p class="text-2xl font-semibold tracking-tight text-zinc-900">{footerBrand.title}</p>
            </div>
            <p class="mt-4 leading-7 text-zinc-600">{footerBrand.description}</p>
            <div class="mt-6 space-y-2 text-zinc-500">
              {footerBrand.legalLines.map((line) => <p>{line}</p>)}
            </div>
          </div>

          <div>
            <p class="text-sm font-semibold text-zinc-500">iOS 端</p>
            <ul class="mt-5 space-y-3">
              {
                iosPrimaryLinks.map((link) => (
                  <li>
                    <a href={link.href} class="transition-colors duration-200 hover:text-zinc-900">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
            <ul class="mt-5 space-y-3 border-t border-zinc-200 pt-5">
              {
                iosSourceLinks.map((link) => (
                  <li>
                    <a href={link.href} class="transition-colors duration-200 hover:text-zinc-900">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div>
            <p class="text-sm font-semibold text-zinc-500">Android 端</p>
            <ul class="mt-5 space-y-3">
              {
                androidPrimaryLinks.map((link) => (
                  <li>
                    <a href={link.href} class="transition-colors duration-200 hover:text-zinc-900">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
            <ul class="mt-5 space-y-3 border-t border-zinc-200 pt-5">
              {
                androidSourceLinks.map((link) => (
                  <li>
                    <a href={link.href} class="transition-colors duration-200 hover:text-zinc-900">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="col-span-2 lg:col-span-1">
            <p class="text-sm font-semibold text-zinc-500">社区</p>
            <ul class="mt-5 space-y-3">
              {
                communityLinks.map((link) => (
                  <li>
                    <a href={link.href} class="transition-colors duration-200 hover:text-zinc-900">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>

<style>
  [data-topbar-shell] {
    row-gap: 0;
  }

  [data-topbar-nav-panel] {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transition:
      max-height 240ms ease,
      opacity 180ms ease;
  }

  @media (max-width: 767px) {
    [data-topbar-shell][data-topbar-expanded="true"] {
      row-gap: 0.75rem;
      padding-bottom: 1rem;
    }

    [data-topbar-shell][data-topbar-expanded="true"] [data-topbar-nav-panel] {
      max-height: 20rem;
      opacity: 1;
      pointer-events: auto;
      visibility: visible;
    }
  }

  @media (min-width: 768px) {
    [data-topbar-nav-panel] {
      max-height: none;
      overflow: visible;
      opacity: 1;
      pointer-events: auto;
      visibility: visible;
    }
  }
</style>
